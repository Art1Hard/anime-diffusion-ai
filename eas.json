{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
			"android": {
				"buildType": "apk"
			}
    },
    "preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_SD_HOST": "http://192.168.0.19:7860"
			}
		},
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
